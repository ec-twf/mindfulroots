---
// Transparent, criterion-based product comparison.
// Reusable across product hubs ("best X") and future VS / comparison posts.
// Desktop (md+): a scan-by-column table. Mobile (<md): one stacked card per
// product — same data, two presentations, no horizontal scroll on phones.
import { retailerLink, goLink, retailerNameFor, RETAILER_NAME } from '../config';

interface Row {
  brand: string;
  productName: string;
  iherbKeyword: string;
  cells: string[];
  pass?: boolean;
  pick?: boolean;
}
interface Props {
  criterion?: string;
  columns?: string[];
  rows: Row[];
  /** Product slug. Sends the `pick` row through the /go/ router so it lands on
   *  whichever program that product is currently on; the other rows are
   *  reference brands we have no program for, so they stay on the marketplace. */
  goSlug?: string;
}
const { criterion, columns = [], rows, goSlug } = Astro.props;

const rowHref = (r: Row) =>
  r.pick && goSlug ? goLink(goSlug, 'comparison') : retailerLink(r.iherbKeyword);
const rowRetailer = (r: Row) =>
  r.pick && goSlug ? retailerNameFor(goSlug) : RETAILER_NAME;
---
<section class="not-prose" aria-label="Product comparison">
  {criterion && (
    <div class="text-xs text-ink-soft leading-relaxed border border-mist rounded-md bg-paper p-3 mb-3">
      <p class="font-mono uppercase tracking-wider text-moss mb-1 text-[0.62rem]">How we judge these</p>
      <p>{criterion}</p>
    </div>
  )}

  {/* Desktop: table (md and up). Hidden on phones, so its min-width never forces a scroll there. */}
  <div class="hidden md:block overflow-x-auto overscroll-x-contain border border-mist rounded-lg bg-card">
    <table class="w-full text-sm border-collapse min-w-[28rem]">
      <thead>
        <tr class="bg-paper text-left">
          <th class="font-mono uppercase tracking-wider text-moss text-[0.62rem] font-medium px-3 py-2.5 border-b border-mist w-[38%] min-w-[11rem]">Product</th>
          <th class="font-mono uppercase tracking-wider text-moss text-[0.62rem] font-medium px-3 py-2.5 border-b border-mist w-[32%] min-w-[9rem]">Product</th>
          {columns.map((c) => (
            <th class="font-mono uppercase tracking-wider text-moss text-[0.62rem] font-medium px-3 py-2.5 border-b border-mist whitespace-nowrap">{c}</th>
          ))}
          <th class="font-mono uppercase tracking-wider text-moss text-[0.62rem] font-medium px-3 py-2.5 border-b border-mist text-center">Meets it</th>
          <th class="px-3 py-2.5 border-b border-mist"><span class="sr-only">Link</span></th>
        </tr>
      </thead>      <tbody>
        {rows.map((r) => (
          <tr class={r.pick ? 'bg-pick-row' : ''}>
            <td class="px-3 py-3 border-b border-mist align-top">
              <div class="flex items-start gap-2">
                {r.pick && (
                  <span class="font-mono text-[0.55rem] uppercase tracking-wider bg-saffron text-on-saffron rounded px-1.5 py-0.5 mt-0.5 whitespace-nowrap">Our pick</span>
                )}
                <span class="min-w-0">
                  <span class="block font-medium text-moss-deep leading-snug">{r.brand}</span>
                  <span class="block text-ink-soft text-xs leading-snug line-clamp-2">{r.productName}</span>
                </span>
              </div>
            </td>
            {r.cells.map((cell) => (
              <td class="px-3 py-3 border-b border-mist align-top text-ink-soft leading-snug">{cell}</td>
            ))}
            <td class="px-3 py-3 border-b border-mist align-top text-center">
              {r.pass !== false ? (
                <span class="text-moss" title="Meets our criterion" aria-label="Yes">✓</span>
              ) : (
                <span class="text-ink-soft" title="Does not meet our criterion" aria-label="No">—</span>
              )}
            </td>
            <td class="px-3 py-3 border-b border-mist align-top whitespace-nowrap">
             <a href={rowHref(r)} target="_blank" rel="nofollow sponsored noopener"
                 class="text-saffron-deep hover:text-moss-deep underline underline-offset-2 text-xs">
                {rowRetailer(r)} →
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  {/* Mobile: stacked cards (below md). One product per block, label -> value pairs. */}
  <ul role="list" class="md:hidden space-y-3">
    {rows.map((r) => (
      <li class={`border border-mist rounded-lg p-4 ${r.pick ? 'bg-pick-row' : 'bg-card'}`}>
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <span class="block font-medium text-moss-deep leading-snug">{r.brand}</span>
            <span class="block text-ink-soft text-xs leading-snug">{r.productName}</span>
          </div>
          {r.pick && (
            <span class="shrink-0 font-mono text-[0.55rem] uppercase tracking-wider bg-saffron text-on-saffron rounded px-1.5 py-0.5 whitespace-nowrap">Our pick</span>
          )}
        </div>

        <dl class="mt-3 border-t border-mist pt-3 space-y-2.5">
          {columns.map((c, i) => (
            <div>
              <dt class="font-mono uppercase tracking-wider text-moss text-[0.62rem]">{c}</dt>
              <dd class="text-ink text-sm leading-snug">{r.cells[i]}</dd>
            </div>
          ))}
          <div class="flex items-center gap-2 pt-0.5">
            <dt class="font-mono uppercase tracking-wider text-moss text-[0.62rem]">Meets our criterion</dt>
            <dd class="text-sm">
              {r.pass !== false ? (
                <span class="text-moss" title="Meets our criterion" aria-label="Yes">✓</span>
              ) : (
                <span class="text-ink-soft" title="Does not meet our criterion" aria-label="No">—</span>
              )}
            </dd>
          </div>
        </dl>

        <a href={rowHref(r)} target="_blank" rel="nofollow sponsored noopener"
           class="mt-4 flex items-center justify-center gap-1 rounded-md border border-mist bg-paper py-2.5 text-sm font-medium text-saffron-deep hover:text-moss-deep">
          View on {rowRetailer(r)} <span aria-hidden="true">→</span>
        </a>
      </li>
    ))}
  </ul>

  <p class="text-[0.68rem] text-ink-soft mt-2">
    Specs verified against live listings at time of writing and can change — confirm on the product page.
    Links are affiliate links; <a href="/disclosure/" class="underline">details</a>.
  </p>
</section>
