---
import AffiliateButton from './AffiliateButton.astro';
import EvidenceTag from './EvidenceTag.astro';
import { ctaLabel } from '../config';
import { priceLabel } from '../lib/prices';

type Placement = 'buybox' | 'sticky-bar' | 'home-pick' | 'in-article' | 'guide-hero' | 'guide-pick' | 'generic';

interface Props {
  slug: string;
  title: string;
  category: string;
  evidence: 'Emerging' | 'Moderate' | 'Well-studied';
  placement?: Placement; // affiliate-analytics tag; defaults to the homepage context
  rank?: number;         // when set, shows a "#N" ordinal (used on guide pages)
  rec: {
    brand: string;
    productName: string;
    iherbKeyword: string;
    priceDisplay?: string;
    image?: string;
    imageAlt?: string;
  };
}
const { slug, title, category, evidence, placement = 'home-pick', rank, rec } = Astro.props;
---
<article class="group bg-card border border-mist rounded-lg flex flex-col overflow-hidden transition-shadow hover:shadow-card">
  {/* Image, or branded botanical placeholder keyed to rec.image */}
  <div class="aspect-[16/10] bg-mist/40 border-b border-mist flex items-center justify-center overflow-hidden">
    {rec.image ? (
      <img src={rec.image} alt={rec.imageAlt ?? `${rec.brand} ${rec.productName}`} loading="lazy" class="w-full h-full object-cover" />
    ) : (
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="opacity-40">
        <path d="M12 21V8M12 8c0-3 2-5 5-5 0 3-2 5-5 5Zm0 0c0-3-2-5-5-5 0 3 2 5 5 5Zm0 6c0-2.4 1.6-4 4-4 0 2.4-1.6 4-4 4Zm0 0c0-2.4-1.6-4-4-4 0 2.4 1.6 4 4 4Z"
          stroke="var(--color-moss)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    )}
  </div>

  <div class="p-5 flex flex-col gap-3 flex-1">
    <div class="flex items-start justify-between gap-3">
      <p class="eyebrow">
        {rank && <span class="font-mono text-[0.68rem] text-ink-soft mr-1.5">#{rank}</span>}
        {category}
      </p>
      <EvidenceTag level={evidence} />
    </div>

    <h3 class="text-xl text-moss-deep">
      <a href={`/products/${slug}/`} class="hover:text-saffron-deep">{title}</a>
    </h3>

    <hr class="specimen-rule" />

    <div class="text-sm">
      <p class="eyebrow mb-1">Our pick</p>
      <p class="font-medium text-moss-deep leading-snug">{rec.brand}</p>
      <p class="text-ink-soft leading-snug">{rec.productName}</p>
      {(priceLabel(slug) ?? rec.priceDisplay) && (
        <p class="mt-2 text-sm font-medium text-moss-deep">{priceLabel(slug) ?? rec.priceDisplay}</p>
      )}
    </div>

    <div class="mt-auto space-y-3 pt-1">
      <AffiliateButton
        keyword={rec.iherbKeyword}
        goSlug={slug}
        label={ctaLabel(slug, rec.brand)}
        placement={placement}
        fullWidth
      />
      <a href={`/products/${slug}/`} class="inline-block text-sm font-medium text-moss-deep group-hover:underline underline-offset-4">
        Read the full review →
      </a>
    </div>
  </div>
</article>
