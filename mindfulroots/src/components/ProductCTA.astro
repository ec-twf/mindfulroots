---
import AffiliateButton from './AffiliateButton.astro';
import EvidenceTag from './EvidenceTag.astro';
import { ctaLabel } from '../config';

interface Props {
  /** Product content-collection slug (for the "Full review →" link) */
  slug: string;
  /** Product title, e.g. "Magnesium Glycinate" */
  title: string;
  evidence: 'Emerging' | 'Moderate' | 'Well-studied';
  rec: {
    brand: string;
    productName: string;
    iherbKeyword: string;
    priceDisplay?: string;
    image?: string;
    imageAlt?: string;
  };
}
const { slug, title, evidence, rec } = Astro.props;
---
<aside class="not-prose bg-card border border-mist rounded-lg p-5 my-8 flex flex-col sm:flex-row gap-5">
  {/* Image, or branded botanical placeholder keyed to rec.image */}
  <div class="sm:w-36 shrink-0 aspect-[16/10] sm:aspect-square bg-mist/40 border border-mist rounded-md flex items-center justify-center overflow-hidden">
    {rec.image ? (
      <img src={rec.image} alt={rec.imageAlt ?? `${rec.brand} ${rec.productName}`} loading="lazy" class="w-full h-full object-cover" />
    ) : (
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="opacity-40">
        <path d="M12 21V8M12 8c0-3 2-5 5-5 0 3-2 5-5 5Zm0 0c0-3-2-5-5-5 0 3 2 5 5 5Zm0 6c0-2.4 1.6-4 4-4 0 2.4-1.6 4-4 4Zm0 0c0-2.4-1.6-4-4-4 0 2.4 1.6 4 4 4Z"
          stroke="var(--color-moss)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    )}
  </div>

  <div class="flex-1 flex flex-col gap-3">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <p class="eyebrow">Our pick for {title}</p>
      <EvidenceTag level={evidence} />
    </div>

    <div>
      <p class="font-medium text-moss-deep leading-snug">{rec.brand}</p>
      <p class="text-sm text-ink-soft leading-snug">{rec.productName}</p>
      {rec.priceDisplay && (
        <p class="mt-1 text-sm font-medium text-moss-deep">{rec.priceDisplay}</p>
      )}
    </div>

    <div class="mt-auto flex flex-col gap-2 pt-1">
      <AffiliateButton
        keyword={rec.iherbKeyword}
        goSlug={slug}
        label={ctaLabel(slug, rec.brand)}
        placement="in-article"
        compact
      />
      <a href={`/products/${slug}/`} class="text-sm font-medium text-moss-deep hover:text-saffron-deep hover:underline underline-offset-4">
        Full review →
      </a>
    </div>
  </div>
</aside>
