---
/* Light/dark theme toggle. The no-FOUC script in Base.astro <head> sets
   document.documentElement.dataset.theme before first paint; this button
   flips it and persists the choice. Icons swap via [data-theme] CSS only. */
---
<button
  type="button"
  id="theme-toggle"
  class="p-1.5 rounded text-ink-soft hover:text-saffron-deep focus:outline-none focus-visible:ring-2 focus-visible:ring-moss"
  aria-label="Switch to dark theme"
>
  {/* Moon — shown in light mode (action: switch to dark) */}
  <svg class="tt-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path
      d="M20.5 14.1A8.5 8.5 0 0 1 9.9 3.5a8.5 8.5 0 1 0 10.6 10.6Z"
      stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
    />
  </svg>
  {/* Sun — shown in dark mode (action: switch to light) */}
  <svg class="tt-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" />
    <path
      d="M12 2.5v2.2M12 19.3v2.2M2.5 12h2.2M19.3 12h2.2M5.3 5.3l1.5 1.5M17.2 17.2l1.5 1.5M18.7 5.3l-1.5 1.5M6.8 17.2l-1.5 1.5"
      stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
    />
  </svg>
</button>

<style is:global>
  #theme-toggle .tt-sun { display: none; }
  [data-theme="dark"] #theme-toggle .tt-sun { display: block; }
  [data-theme="dark"] #theme-toggle .tt-moon { display: none; }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  const root = document.documentElement;

  function syncLabel() {
    btn?.setAttribute(
      'aria-label',
      root.dataset.theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme'
    );
  }
  syncLabel();

  btn?.addEventListener('click', () => {
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    try {
      localStorage.theme = next;
    } catch {}
    syncLabel();
  });

  // Follow system changes only while the visitor has no stored preference
  matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    let stored: string | undefined;
    try {
      stored = localStorage.theme;
    } catch {}
    if (!stored) {
      root.dataset.theme = e.matches ? 'dark' : 'light';
      syncLabel();
    }
  });
</script>
