---
import type { MarkdownHeading } from 'astro';
interface Props {
  /** Headings returned by Astro's render(post). */
  headings: MarkdownHeading[];
}
const { headings } = Astro.props;
const h2s = headings.filter((h) => h.depth === 2);
---
{h2s.length >= 4 && (
  <details class="bg-card border border-mist rounded-lg px-5 py-3 my-6">
    <summary class="eyebrow cursor-pointer select-none flex items-center justify-between gap-3 marker:content-none [&::-webkit-details-marker]:hidden">
      On this page
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-moss shrink-0">
        <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </summary>
    <ul class="mt-3 space-y-1.5">
      {h2s.map((h) => (
        <li>
          <a href={`#${h.slug}`} class="text-sm text-moss-deep hover:text-saffron-deep hover:underline underline-offset-4">{h.text}</a>
        </li>
      ))}
    </ul>
  </details>
)}
