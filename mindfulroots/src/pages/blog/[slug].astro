---
import Base from '../../layouts/Base.astro';
import SupportNotice from '../../components/SupportNotice.astro';
import EvidenceTag from '../../components/EvidenceTag.astro';
import Byline from '../../components/Byline.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ProductCTA from '../../components/ProductCTA.astro';
import { getCollection, render } from 'astro:content';
import { SITE } from '../../config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { data } = post;
const { Content, headings } = await render(post);

const products = await getCollection('products');
const related = data.relatedProducts
  .map((slug) => products.find((p) => p.id === slug))
  .filter(Boolean);

// Evidence tier shown in the header reflects the primary supplement this post
// covers (the first related product). Undefined when a post has no product.
const evidenceLevel = related[0]?.data.evidence;

// In-article conversion card: auto-placed after the prose when the primary
// related product carries a verified recommendedProduct. Zero content edits.
const ctaProduct = related[0];
const ctaRec = ctaProduct?.data.recommendedProduct;

const date = data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const pageUrl = new URL(`/blog/${post.id}/`, Astro.site).toString();
const articleId = new URL(`/blog/${post.id}/#article`, Astro.site).toString();
const ogImage = new URL(data.image ?? '/og-default.png', Astro.site).toString();
const logoUrl = new URL('/logo.png', Astro.site).toString();

const graphItems: Array<Record<string, unknown>> = [
  {
    '@type': 'Article',
    '@id': articleId,
    headline: data.title,
    description: data.description,
    image: { '@type': 'ImageObject', url: ogImage, width: 1200, height: 630 },
    datePublished: data.pubDate.toISOString(),
    ...(data.updatedDate && { dateModified: data.updatedDate.toISOString() }),
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.prose-mr > p:first-child', '.prose-mr > h2:last-of-type + p'],
    },
    url: new URL(`/blog/${post.id}/`, Astro.site).toString(),
    author: {
      '@type': 'Person',
      name: 'Enoch C.',
      url: new URL('/authors/enoch-c/', Astro.site).toString(),
      sameAs: ['https://www.linkedin.com/in/enoch-cheung-ec/'],
    },
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      url: String(Astro.site),
      logo: {
        '@type': 'ImageObject',
        url: logoUrl,
        width: 600,
        height: 60,
      },
    },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: String(Astro.site) },
      { '@type': 'ListItem', position: 2, name: 'Journal', item: new URL('/blog/', Astro.site).toString() },
      { '@type': 'ListItem', position: 3, name: data.title, item: new URL(`/blog/${post.id}/`, Astro.site).toString() },
    ],
  },
];

if (data.faq && data.faq.length > 0) {
  graphItems.push({
    '@type': 'FAQPage',
    mainEntity: data.faq.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  });
}

// MedicalWebPage signals YMYL/health-content intent to Google. `reviewedBy`
// reflects editorial review by Enoch C.; when a clinical reviewer is engaged,
// point this at that person instead.
graphItems.push({
  '@type': 'MedicalWebPage',
  '@id': new URL(`/blog/${post.id}/#webpage`, Astro.site).toString(),
  url: pageUrl,
  name: data.title,
  description: data.description,
  lastReviewed: (data.updatedDate ?? data.pubDate).toISOString(),
  reviewedBy: {
    '@type': 'Person',
    name: 'Enoch C.',
    url: new URL('/authors/enoch-c/', Astro.site).toString(),
  },
  mainContentOfPage: { '@id': articleId },
});

const schema = {
  '@context': 'https://schema.org',
  '@graph': graphItems,
};
---
<Base title={data.title} description={data.description} schema={schema} ogType="article" image={data.image}>
  <Breadcrumb crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Journal', href: '/blog/' },
    { label: data.title },
  ]} />

  <article
    class="mx-auto max-w-3xl px-5 pt-6 pb-4"
    data-pagefind-body
    data-pagefind-meta={`cluster:${data.cluster}`}
  >
    <div class="flex flex-wrap items-center gap-3 mb-2">
      <p class="eyebrow">{data.cluster}</p>
      {evidenceLevel && <EvidenceTag level={evidenceLevel} />}
    </div>
    <h1 class="font-display text-3xl sm:text-4xl text-moss-deep leading-tight">{data.title}</h1>
    <p class="mt-3 text-ink-soft">{data.description}</p>
    <time class="block mt-3 font-mono text-xs text-ink-soft" datetime={data.pubDate.toISOString()}>{date}</time>
    {data.updatedDate && (
      <p class="font-mono text-xs text-ink-soft mt-0.5">Updated {data.updatedDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}</p>
    )}
    <Byline type="article" />
    <TableOfContents headings={headings} />
    <hr class="specimen-rule my-6" />
    <div class="prose-mr"><Content /></div>
    {ctaProduct && ctaRec && (
      <ProductCTA
        slug={ctaProduct.id}
        title={ctaProduct.data.title}
        evidence={ctaProduct.data.evidence}
        rec={ctaRec}
      />
    )}
  </article>

  {related.length > 0 && (
    <section class="mx-auto max-w-3xl px-5 py-4">
      <div class="bg-card border border-mist rounded-lg p-5">
        <p class="eyebrow mb-3">Supplements mentioned</p>
        <ul class="space-y-2">
          {related.map((p) => (
            <li>
              <a href={`/products/${p!.id}/`} class="flex items-center justify-between gap-3 group">
                <span class="flex flex-wrap items-center gap-2">
                  <span class="text-moss-deep font-medium group-hover:text-saffron-deep">{p!.data.title}</span>
                  <EvidenceTag level={p!.data.evidence} />
                </span>
                <span class="text-saffron-deep text-sm group-hover:underline underline-offset-4 shrink-0">View profile →</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="mx-auto max-w-3xl px-5 py-6">
    <SupportNotice />
  </section>
</Base>
