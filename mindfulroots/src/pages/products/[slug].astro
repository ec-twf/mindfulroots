---
import Base from '../../layouts/Base.astro';
import Byline from '../../components/Byline.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EvidenceTag from '../../components/EvidenceTag.astro';
import BuyBox from '../../components/BuyBox.astro';
import StickyBuyBar from '../../components/StickyBuyBar.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import WarningBox from '../../components/WarningBox.astro';
import SupportNotice from '../../components/SupportNotice.astro';
import { getCollection, render } from 'astro:content';
import { RETAILER_NAME, retailerLink } from '../../config';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;
const { Content } = await render(product);

// Resolve related blog posts (the cluster "spokes")
const allPosts = await getCollection('blog');
const related = data.relatedPosts
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean);

// Resolve related product hubs (sibling internal links)
const allProducts = await getCollection('products');
const relatedProds = (data.relatedProducts ?? [])
  .map((slug) => allProducts.find((p) => p.id === slug))
  .filter(Boolean);

// Recommended-product helpers (only when present)
const rec = data.recommendedProduct;
const verifiedLabel = rec
  ? rec.verifiedDate.toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
    })
  : null;

// This page is a third-party affiliate comparison (no direct sale, no
// site-controlled real-time price) — not a page that sells one product at a
// fixed price, so Product+Offer schema is the wrong fit (and Google's Offer
// validation requires a `price` this site can't honestly provide). A Review
// node was tried too, but Review.itemReviewed only accepts a fixed Google
// whitelist (Product, Organization, etc.) — Product re-triggers the Product
// snippet checks, and no other type on the list fits an editorial pick with
// no real user reviews. Simplest correct fix: no Review/Rating markup here,
// just the ItemList for the compared products (plain reference links).
const comparisonRows = data.comparison?.rows ?? [];
const itemListElements = comparisonRows.length > 0
  ? [rec, ...comparisonRows].filter(Boolean).map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: `${item.brand} ${item.productName}`,
      url: retailerLink(item.iherbKeyword),
    }))
  : [];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    ...(itemListElements.length > 0 ? [{
      '@type': 'ItemList',
      itemListElement: itemListElements,
    }] : []),
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: String(Astro.site) },
        { '@type': 'ListItem', position: 2, name: 'Supplements', item: new URL('/products/', Astro.site).toString() },
        { '@type': 'ListItem', position: 3, name: data.title, item: new URL(`/products/${product.id}/`, Astro.site).toString() },
      ],
    },
  ],
};
---

<Base
  title={data.seoTitle ?? data.title}
  description={data.metaDescription ?? data.shortDescription}
  schema={schema}
  ogType="product"
>
  <Breadcrumb crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Supplements', href: '/products/' },
    { label: data.title },
  ]} />

  <article
    class="mx-auto max-w-5xl px-5 pb-6 grid md:grid-cols-[1fr_300px] gap-x-10"
    data-pagefind-body
    data-pagefind-meta={`category:${data.category}`}
  >
    <!-- Intro block — stays first on mobile and desktop -->
    <div class="min-w-0 order-1 md:col-start-1 md:row-start-1">
      <p class="eyebrow mb-2">{data.category}</p>
      <h1 class="font-display text-3xl sm:text-4xl text-moss-deep">{data.title}</h1>
      {data.latinName && <p class="font-mono text-sm text-ink-soft italic mt-1">{data.latinName}</p>}

      <div class="mt-4"><EvidenceTag level={data.evidence} /></div>

      {rec && (
        <p class="mt-2 font-mono text-xs text-ink-soft">
          Last reviewed{' '}
          <time datetime={rec.verifiedDate.toISOString()}>
            {rec.verifiedDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
          </time>
        </p>
      )}

      <p class="mt-5 text-lg text-ink leading-relaxed">{data.shortDescription}</p>

      {data.comparison && data.comparison.rows.length > 0 && (
        <p class="mt-3">
          <a href="#comparison" class="text-moss-deep hover:text-saffron-deep underline underline-offset-2 text-sm font-medium">How the options compare ↓</a>
        </p>
      )}

      <Byline type="product" />

      {data.interactionWarning && (
        <div class="mt-6">
          <WarningBox title="Medication interaction — read first">
            <p set:html={data.interactionWarning.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
          </WarningBox>
        </div>
      )}
    </div>

    <!-- Body block — sits after the buy box on mobile, left column on desktop -->
    <div class="min-w-0 order-3 md:col-start-1 md:row-start-2">
      {data.comparison && data.comparison.rows.length > 0 && (
        <section id="comparison" class="mt-7 scroll-mt-24">
          <p class="eyebrow mb-2">Our pick, and why</p>
          <h2 class="font-display text-2xl text-moss-deep mb-3">Choosing a {data.title.toLowerCase()} on {RETAILER_NAME}</h2>
          {data.comparison.verdict && (
            <p class="text-ink leading-relaxed mb-4">{data.comparison.verdict}</p>
          )}
          <ComparisonTable
            criterion={data.comparison.criterion ?? data.qualityCriterion}
            columns={data.comparison.columns}
            rows={data.comparison.rows}
          />
        </section>
      )}

      <hr class="specimen-rule my-7" />

      <section class="prose-mr max-w-none">
        <Content />
      </section>
    </div>

    <!-- Sidebar: the buy box + at-a-glance -->
    <aside class="order-2 md:col-start-2 md:row-start-1 md:row-span-2 md:sticky md:top-24 self-start space-y-5 mt-8 md:mt-0">
      <BuyBox data={data} rec={rec} verifiedLabel={verifiedLabel} relatedProds={relatedProds} />
    </aside>
  </article>

  {related.length > 0 && (
    <section class="mx-auto max-w-5xl px-5 py-8">
      <p class="eyebrow mb-3">Keep reading</p>
      <div class="grid gap-4 sm:grid-cols-2">
        {related.map((post) => (
          <a href={`/blog/${post!.id}/`} class="block bg-card border border-mist rounded-lg p-5 hover:shadow-card transition-shadow">
            <p class="eyebrow mb-1">{post!.data.cluster}</p>
            <h3 class="text-lg text-moss-deep leading-snug">{post!.data.title}</h3>
            <p class="text-sm text-ink-soft mt-1.5 leading-relaxed">{post!.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mx-auto max-w-5xl px-5 py-6 pb-24 md:pb-6">
    <SupportNotice />
  </section>

  {rec && <StickyBuyBar rec={rec} />}
</Base>
