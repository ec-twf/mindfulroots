---
import Base from '../../layouts/Base.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';
import EvidenceTag from '../../components/EvidenceTag.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import WarningBox from '../../components/WarningBox.astro';
import SupportNotice from '../../components/SupportNotice.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;
const { Content } = await render(product);

// Resolve related blog posts (the cluster "spokes")
const allPosts = await getCollection('blog');
const related = data.relatedPosts
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean);

// Resolve related product hubs (sibling internal links)
const allProducts = await getCollection('products');
const relatedProds = (data.relatedProducts ?? [])
  .map((slug) => allProducts.find((p) => p.id === slug))
  .filter(Boolean);

// Recommended-product helpers (only when present)
const rec = data.recommendedProduct;
const verifiedLabel = rec
  ? rec.verifiedDate.toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
    })
  : null;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: rec ? rec.productName : data.title,
  category: data.category,
  description: data.shortDescription,
  ...(rec && {
    brand: { '@type': 'Brand', name: rec.brand },
    ...(rec.image && { image: new URL(rec.image, Astro.site).toString() }),
  }),
};
---

<Base
  title={data.seoTitle ?? data.title}
  description={data.metaDescription ?? data.shortDescription}
  schema={schema}
  ogType="product"
>
  <div class="mx-auto max-w-5xl px-5 pt-8 pb-4 text-sm">
    <a href="/products/" class="text-ink-soft hover:text-saffron-deep">← All supplements</a>
  </div>

  <article class="mx-auto max-w-5xl px-5 pb-6 grid lg:grid-cols-[1fr_320px] gap-10">
    <!-- Main column -->
    <div>
      <p class="eyebrow mb-2">{data.category}</p>
      <h1 class="font-display text-3xl sm:text-4xl text-moss-deep">{data.title}</h1>
      {data.latinName && <p class="font-mono text-sm text-ink-soft italic mt-1">{data.latinName}</p>}

      <div class="mt-4"><EvidenceTag level={data.evidence} /></div>

      <p class="mt-5 text-lg text-ink leading-relaxed">{data.shortDescription}</p>

      {data.interactionWarning && (
        <div class="mt-6">
          <WarningBox title="Medication interaction — read first">
            <p set:html={data.interactionWarning.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
          </WarningBox>
        </div>
      )}

      <hr class="specimen-rule my-7" />

      <section class="prose-mr max-w-none">
        <Content />
      </section>

      {data.comparison && data.comparison.rows.length > 0 && (
        <section class="mt-9">
          <p class="eyebrow mb-2">How the options compare</p>
          <h2 class="font-display text-2xl text-moss-deep mb-4">Picking a {data.title.toLowerCase()} on iHerb</h2>
          <ComparisonTable
            criterion={data.comparison.criterion ?? data.qualityCriterion}
            columns={data.comparison.columns}
            rows={data.comparison.rows}
          />
        </section>
      )}
    </div>

    <!-- Sidebar: the buy box + at-a-glance -->
    <aside class="lg:sticky lg:top-24 self-start space-y-5">
      <div class="bg-card border border-mist rounded-lg p-5 space-y-4">
        <div>
          <p class="eyebrow mb-2">Our pick</p>

          {rec ? (
            <div class="space-y-3">
              <div class="text-sm">
                <p class="font-medium text-moss-deep leading-snug">{rec.brand}</p>
                <p class="text-ink-soft leading-snug">{rec.productName}</p>
              </div>

              {data.qualityCriterion && (
                <div class="text-xs text-ink-soft leading-relaxed border border-mist rounded-md bg-paper p-3">
                  <p class="font-mono uppercase tracking-wider text-moss mb-1 text-[0.62rem]">Our criterion</p>
                  <p>{data.qualityCriterion}</p>
                </div>
              )}

              {(rec.concentrationNote || rec.oxidationNote) && (
                <ul class="text-xs text-ink-soft space-y-1">
                  {rec.concentrationNote && (
                    <li class="flex gap-1.5"><span class="text-moss" aria-hidden="true">✓</span><span>{rec.concentrationNote}</span></li>
                  )}
                  {rec.oxidationNote && (
                    <li class="flex gap-1.5"><span class="text-moss" aria-hidden="true">✓</span><span>{rec.oxidationNote}</span></li>
                  )}
                </ul>
              )}

              <AffiliateButton keyword={rec.iherbKeyword} label={`View ${rec.brand} on iHerb`} />

              <p class="text-[0.68rem] text-ink-soft">
                Spec verified {verifiedLabel}
                {data.criterionSourceUrl && (
                  <> · <a href={data.criterionSourceUrl} target="_blank" rel="noopener" class="underline">why this criterion</a></>
                )}
              </p>
            </div>
          ) : (
            <AffiliateButton keyword={data.iherbKeyword} />
          )}
        </div>
        <hr class="specimen-rule" />
        <dl class="text-sm space-y-3">
          <div>
            <dt class="eyebrow">Typical use</dt>
            <dd class="text-ink-soft mt-1 leading-relaxed">{data.typicalUse}</dd>
          </div>
          <div>
            <dt class="eyebrow">Cautions</dt>
            <dd class="text-ink-soft mt-1 leading-relaxed">{data.cautions}</dd>
          </div>
        </dl>
      </div>

      {data.benefits.length > 0 && (
        <div class="bg-card border border-mist rounded-lg p-5">
          <p class="eyebrow mb-2">May support</p>
          <ul class="text-sm text-ink-soft space-y-1.5">
            {data.benefits.map((b) => (
              <li class="flex gap-2"><span class="text-moss mt-0.5">›</span><span>{b}</span></li>
            ))}
          </ul>
        </div>
      )}

      {relatedProds.length > 0 && (
        <div class="bg-card border border-mist rounded-lg p-5">
          <p class="eyebrow mb-2">Related supplements</p>
          <ul class="text-sm space-y-1.5">
            {relatedProds.map((p) => (
              <li class="flex gap-2">
                <span class="text-moss mt-0.5">›</span>
                <a href={`/products/${p!.id}/`} class="text-moss-deep hover:text-saffron-deep underline-offset-2 hover:underline">
                  {p!.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>
  </article>

  {related.length > 0 && (
    <section class="mx-auto max-w-5xl px-5 py-8">
      <p class="eyebrow mb-3">Keep reading</p>
      <div class="grid gap-4 sm:grid-cols-2">
        {related.map((post) => (
          <a href={`/blog/${post!.id}/`} class="block bg-card border border-mist rounded-lg p-5 hover:shadow-[0_4px_18px_rgba(62,92,73,0.12)] transition-shadow">
            <p class="eyebrow mb-1">{post!.data.cluster}</p>
            <h3 class="text-lg text-moss-deep leading-snug">{post!.data.title}</h3>
            <p class="text-sm text-ink-soft mt-1.5 leading-relaxed">{post!.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mx-auto max-w-5xl px-5 py-6">
    <SupportNotice />
  </section>
</Base>
