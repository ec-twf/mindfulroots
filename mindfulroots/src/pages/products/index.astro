---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import FilterPills from '../../components/FilterPills.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SupportNotice from '../../components/SupportNotice.astro';
import { CATEGORY_GROUPS } from '../../lib/taxonomy';
import { getCollection } from 'astro:content';

const products = (await getCollection('products')).sort((a, b) => a.data.order - b.data.order);

// Group products under the 4 shopper-facing taxonomy groups, preserving the
// global `order` sort within each group.
const grouped = CATEGORY_GROUPS.map((group) => ({
  ...group,
  items: products.filter((p) => group.products.includes(p.id)),
})).filter((g) => g.items.length > 0);

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: 'Mood & stress support supplements',
      description: 'Ten evidence-aware mood, stress and sleep-support supplements, each with an honest evidence rating.',
      url: new URL('/products/', Astro.site).toString(),
    },
    {
      '@type': 'ItemList',
      name: 'Mood & stress support supplements',
      itemListElement: products.map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: p.data.title,
        url: new URL(`/products/${p.id}/`, Astro.site).toString(),
        description: p.data.shortDescription,
      })),
    },
  ],
};
---

<Base
  title="Mood & Stress Supplements: Evidence-Rated"
  description="Ten mood, stress and sleep supplements reviewed honestly — each rated Emerging, Moderate or Well-studied on the human research, with plain-spoken cautions."
  schema={schema}
>
  <Breadcrumb crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Supplements' },
  ]} />

  <section class="mx-auto max-w-5xl px-5 pt-6 pb-6">
    <p class="eyebrow mb-3">The full shelf</p>
    <h1 class="font-display text-3xl sm:text-4xl text-moss-deep max-w-2xl">
      Ten supplements, rated by how strong the evidence really is
    </h1>
    <p class="mt-4 max-w-2xl text-ink-soft leading-relaxed">
      These are framed as mood, stress and sleep <em>support</em> — not as treatments for depression
      or any medical condition. Each profile explains what the research shows, who it suits, and the
      cautions that matter. The evidence tier (one to three dots) is our honest read of the strength
      of the human studies.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-4">
    <FilterPills total={products.length} noun="supplement" />
  </section>

  {grouped.map((group) => (
    <section data-group={group.id} class="mx-auto max-w-5xl px-5 pb-8">
      <h2 id={group.id} class="scroll-mt-24 font-display text-2xl text-moss-deep mb-4">{group.label}</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {group.items.map((p) => (
          <div data-card data-evidence={p.data.evidence} class="h-full">
            <ProductCard
              slug={p.id}
              title={p.data.title}
              latinName={p.data.latinName}
              category={p.data.category}
              evidence={p.data.evidence}
              shortDescription={p.data.shortDescription}
            />
          </div>
        ))}
      </div>
    </section>
  ))}

  <section class="mx-auto max-w-5xl px-5 py-8">
    <SupportNotice />
  </section>
</Base>
