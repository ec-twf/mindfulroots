---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import SupportNotice from '../../components/SupportNotice.astro';
import { getCollection } from 'astro:content';

const products = (await getCollection('products')).sort((a, b) => a.data.order - b.data.order);

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: 'Mood & stress support supplements',
      description: 'Ten evidence-aware mood, stress and sleep-support supplements, each with an honest evidence rating.',
      url: new URL('/products/', Astro.site).toString(),
    },
    {
      '@type': 'ItemList',
      name: 'Mood & stress support supplements',
      itemListElement: products.map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: p.data.title,
        url: new URL(`/products/${p.id}/`, Astro.site).toString(),
        description: p.data.shortDescription,
      })),
    },
  ],
};
---

<Base
  title="Mood & Stress Supplements: Evidence-Rated Reviews | MoodSupplement"
  description="Ten mood, stress and sleep-support supplements reviewed honestly — each rated Emerging, Moderate or Well-studied based on the human research, with plain-spoken cautions."
  schema={schema}
>
  <section class="mx-auto max-w-5xl px-5 pt-12 pb-6">
    <p class="eyebrow mb-3">The full shelf</p>
    <h1 class="font-display text-3xl sm:text-4xl text-moss-deep max-w-2xl">
      Ten supplements, rated by how strong the evidence really is
    </h1>
    <p class="mt-4 max-w-2xl text-ink-soft leading-relaxed">
      These are framed as mood, stress and sleep <em>support</em> — not as treatments for depression
      or any medical condition. Each profile explains what the research shows, who it suits, and the
      cautions that matter. The evidence tier (one to three dots) is our honest read of the strength
      of the human studies.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-6">
    <h2 class="sr-only">All supplements</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((p) => (
        <ProductCard
          slug={p.id}
          title={p.data.title}
          latinName={p.data.latinName}
          category={p.data.category}
          evidence={p.data.evidence}
          shortDescription={p.data.shortDescription}
        />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-5 py-8">
    <SupportNotice />
  </section>
</Base>
