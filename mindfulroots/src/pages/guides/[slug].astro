---
import Base from '../../layouts/Base.astro';
import Byline from '../../components/Byline.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BestPickCard from '../../components/BestPickCard.astro';
import GuideHeroSlot from '../../components/GuideHeroSlot.astro';
import StickyBuyBar from '../../components/StickyBuyBar.astro';
import EvidenceTag from '../../components/EvidenceTag.astro';
import SupportNotice from '../../components/SupportNotice.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { getCollection, render } from 'astro:content';
import { SITE } from '../../config';

export async function getStaticPaths() {
  const hubs = await getCollection('hubs');
  return hubs
    .filter((h) => !h.data.draft)
    .map((hub) => ({ params: { slug: hub.id }, props: { hub } }));
}

const { hub } = Astro.props;
const { data } = hub;
const { Content } = await render(hub);

// Single source of truth for whether this hub has an FAQ: gates BOTH the
// visible FAQ section below AND the FAQPage JSON-LD in the schema graph —
// copied verbatim from the blog template's `hasFaq` pattern (the two must
// never diverge; that was a fixed bug there and the rule carries over here).
const hasFaq = Boolean(data.faq && data.faq.length > 0);

const allProducts = await getCollection('products');
const picks = data.products
  .map((slug) => allProducts.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

// The #1 pick becomes the hero buy box (direct affiliate CTA), but only when it
// actually carries a recommendedProduct. Otherwise everything stays in the grid.
const hero = picks[0]?.data.recommendedProduct ? picks[0] : undefined;
const gridPicks = hero ? picks.slice(1) : picks;

const allPosts = await getCollection('blog');
const supportingPosts = data.supportingPosts
  .map((slug) => allPosts.find((p) => !p.data.draft && p.id === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const allHubs = await getCollection('hubs');
const relatedHubs = data.relatedHubs
  .map((slug) => allHubs.find((h) => !h.data.draft && h.id === slug))
  .filter((h): h is NonNullable<typeof h> => Boolean(h));

const date = data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const pageUrl = new URL(`/guides/${hub.id}/`, Astro.site).toString();
const ogImage = new URL(data.image ?? '/og-default.png', Astro.site).toString();

// ─── Schema.org @graph ───────────────────────────────────────────────────
// MedicalWebPage + a url-only ItemList of the picks + BreadcrumbList +
// conditional FAQPage. Deliberately NO Product / Offer / Review /
// AggregateRating nodes here — those were removed from products/[slug].astro
// in commit 1a1f3b7 after Google rejected them for a page with no real
// user reviews and no site-controlled fixed price, and the same reasoning
// applies here even more directly (this page doesn't sell anything at all,
// it's an evidence roundup that links out to product pages). The ItemList
// below is plain reference links, matching the ItemList already used on
// products/[slug].astro for its comparison rows.
const graphItems: Array<Record<string, unknown>> = [
  {
    '@type': 'MedicalWebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: data.title,
    description: data.description,
    about: { '@type': 'MedicalCondition', name: data.conditionLabel },
    lastReviewed: (data.updatedDate ?? data.pubDate).toISOString(),
    reviewedBy: {
      '@type': 'Person',
      name: 'Enoch C.',
      url: new URL('/authors/enoch-c/', Astro.site).toString(),
    },
  },
];

if (picks.length > 0) {
  graphItems.push({
    '@type': 'ItemList',
    itemListElement: picks.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: p.data.title,
      url: new URL(`/products/${p.id}/`, Astro.site).toString(),
    })),
  });
}

graphItems.push({
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: String(Astro.site) },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: new URL('/guides/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: data.title, item: pageUrl },
  ],
});

if (hasFaq) {
  graphItems.push({
    '@type': 'FAQPage',
    mainEntity: data.faq!.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  });
}

const schema = {
  '@context': 'https://schema.org',
  '@graph': graphItems,
};
---
<Base title={data.seoTitle ?? data.title} description={data.metaDescription ?? data.description} schema={schema} ogType="article" image={data.image}>
  <Breadcrumb crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Guides', href: '/guides/' },
    { label: data.title },
  ]} />

  <article class="mx-auto max-w-3xl px-5 pt-6 pb-4" data-pagefind-body data-pagefind-meta={`condition:${data.conditionLabel}`}>
    <p class="eyebrow mb-2">{data.conditionLabel} guide</p>
    <h1 class="font-display text-3xl sm:text-4xl text-moss-deep leading-tight">{data.title}</h1>
    <p class="mt-3 text-ink-soft">{data.description}</p>
    {hero && (
      <a href="#buy" class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-saffron-deep hover:underline underline-offset-4">
        Our top pick: {hero.data.recommendedProduct.brand}
        <span aria-hidden="true">↓</span>
      </a>
    )}
    <time class="block mt-3 font-mono text-xs text-ink-soft" datetime={data.pubDate.toISOString()}>{date}</time>
    {data.updatedDate && (
      <p class="font-mono text-xs text-ink-soft mt-0.5">Updated {data.updatedDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}</p>
    )}
    <Byline type="article" />
    <hr class="specimen-rule my-6" />
    {/* Hero buy box is placed inline by the MDX body (<HeroCTA />), right after
        the top pick's reasoning, so the reader gets context before the CTA. */}
    <div class="prose-mr"><Content components={{ HeroCTA: GuideHeroSlot }} /></div>
  </article>

  {gridPicks.length > 0 && (
    <section class="mx-auto max-w-5xl px-5 py-6">
      <p class="eyebrow mb-3">{hero ? `More picks for ${data.conditionLabel.toLowerCase()}` : `Our picks for ${data.conditionLabel.toLowerCase()}`}</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {gridPicks.map((p, i) => (
          p.data.recommendedProduct ? (
            <BestPickCard
              slug={p.id}
              title={p.data.title}
              category={p.data.category}
              evidence={p.data.evidence}
              placement="guide-pick"
              rank={hero ? i + 2 : i + 1}
              rec={p.data.recommendedProduct}
            />
          ) : (
            <article class="bg-card border border-mist rounded-lg p-5 flex flex-col gap-3">
              <div class="flex items-start justify-between gap-3">
                <p class="eyebrow">{p.data.category}</p>
                <EvidenceTag level={p.data.evidence} />
              </div>
              <h3 class="text-xl text-moss-deep">
                <a href={`/products/${p.id}/`} class="hover:text-saffron-deep">{p.data.title}</a>
              </h3>
              <p class="text-sm text-ink-soft leading-relaxed">{p.data.shortDescription}</p>
              <a href={`/products/${p.id}/`} class="mt-auto text-sm font-medium text-moss-deep hover:text-saffron-deep hover:underline underline-offset-4">
                Read the full review →
              </a>
            </article>
          )
        ))}
      </div>
    </section>
  )}

  {supportingPosts.length > 0 && (
    <section class="mx-auto max-w-3xl px-5 py-4">
      <div class="bg-card border border-mist rounded-lg p-5">
        <p class="eyebrow mb-3">Evidence behind these picks</p>
        <ul class="space-y-2">
          {supportingPosts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="flex items-center justify-between gap-3 group">
                <span class="text-moss-deep font-medium group-hover:text-saffron-deep">{post.data.title}</span>
                <span class="text-saffron-deep text-sm group-hover:underline underline-offset-4 shrink-0">Read →</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {hasFaq && (
    <section class="mx-auto max-w-3xl px-5 py-4">
      <div class="prose-mr">
        <h2>Frequently asked questions</h2>
        {data.faq!.map((item) => (
          <div class="mt-4">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  {relatedHubs.length > 0 && (
    <section class="mx-auto max-w-3xl px-5 py-4">
      <div class="bg-card border border-mist rounded-lg p-5">
        <p class="eyebrow mb-3">Related guides</p>
        <ul class="space-y-2">
          {relatedHubs.map((h) => (
            <li>
              <a href={`/guides/${h.id}/`} class="flex items-center justify-between gap-3 group">
                <span class="text-moss-deep font-medium group-hover:text-saffron-deep">{h.data.title}</span>
                <span class="text-saffron-deep text-sm group-hover:underline underline-offset-4 shrink-0">View guide →</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="mx-auto max-w-3xl px-5 py-6">
    <EmailCapture source="guide-end" compact />
    <SupportNotice />
  </section>

  {hero && <StickyBuyBar slug={hero.id} rec={hero.data.recommendedProduct} />}
</Base>
