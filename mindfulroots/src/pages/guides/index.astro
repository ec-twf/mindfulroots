---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const hubs = (await getCollection('hubs'))
  .filter((h) => !h.data.draft)
  .sort((a, b) => a.data.conditionLabel.localeCompare(b.data.conditionLabel));
---
<Base
  title="Supplement Guides by Goal: Stress, Sleep & Mood"
  description="Condition-first guides that summarise the evidence and point to the right supplement — organised by what you're trying to support, not by ingredient."
>
  <Breadcrumb crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Guides' },
  ]} />
  <section class="mx-auto max-w-5xl px-5 pt-6 pb-6">
    <p class="eyebrow mb-3">Guides</p>
    <h1 class="font-display text-3xl sm:text-4xl text-moss-deep max-w-2xl">
      Start from your goal, not the ingredient
    </h1>
    <p class="mt-4 max-w-2xl text-ink-soft leading-relaxed">
      Each guide summarises what the human evidence supports for one goal, then points you to the
      supplements that fit — with the underlying research a click away, and professional care kept in view.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-12">
    <h2 class="sr-only">All guides</h2>
    {hubs.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {hubs.map((h) => (
          <a href={`/guides/${h.id}/`} class="block h-full bg-card border border-mist rounded-lg p-5 hover:border-saffron-deep transition-colors">
            <p class="eyebrow mb-2">{h.data.conditionLabel}</p>
            <h3 class="text-xl text-moss-deep">{h.data.title}</h3>
            <p class="mt-2 text-sm text-ink-soft leading-relaxed">{h.data.description}</p>
            <span class="mt-3 inline-block text-sm font-medium text-moss-deep">Read the guide →</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-ink-soft">Guides are on the way.</p>
    )}
  </section>
</Base>
