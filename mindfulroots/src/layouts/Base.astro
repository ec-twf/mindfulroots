---
import '../styles/global.css';
import { SITE } from '../config';
import { CATEGORY_GROUPS } from '../lib/taxonomy';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  /** JSON-LD structured data object, rendered as a script tag */
  schema?: Record<string, unknown>;
  ogType?: string;
  /** Override the default OG/Twitter share image */
  image?: string;
}

const { title, description = SITE.description, schema, ogType = 'website', image = '/og-default.png' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
const fullTitle = title === SITE.name ? `${SITE.name} — ${SITE.tagline}` : `${title} · ${SITE.name}`;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f3f6ee" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#141c17" />
    {/* No-FOUC theme init — must run before the stylesheet applies */}
    <script is:inline>
      let theme = 'light';
      try {
        theme = localStorage.theme ?? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      } catch (e) {}
      document.documentElement.dataset.theme = theme;
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />


    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": SITE.name,
      "url": String(Astro.site),
      "logo": {
        "@type": "ImageObject",
        "url": new URL('/logo.png', Astro.site).toString(),
        "width": 600,
        "height": 60,
      },
      "sameAs": ["https://www.linkedin.com/in/enoch-cheung-ec/"],
    })} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-M99Z4RML');</script>
<!-- End Google Tag Manager -->

  </head>

  <body class="min-h-screen flex flex-col">
  <!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M99Z4RML"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-card focus:px-3 focus:py-2 focus:rounded"
      >Skip to content</a
    >

    <header class="border-b border-mist bg-paper/90 backdrop-blur sticky top-0 z-20">
      <div class="mx-auto max-w-5xl px-5 py-4 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2.5 no-underline">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 21V8M12 8c0-3 2-5 5-5 0 3-2 5-5 5Zm0 0c0-3-2-5-5-5 0 3 2 5 5 5Zm0 6c0-2.4 1.6-4 4-4 0 2.4-1.6 4-4 4Zm0 0c0-2.4-1.6-4-4-4 0 2.4 1.6 4 4 4Z"
              stroke="var(--color-moss)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-display text-xl text-moss-deep">{SITE.name}</span>
        </a>

        <div class="flex items-center gap-3 sm:gap-5">
        {/* Desktop nav — hidden on mobile */}
        <nav class="hidden sm:flex items-center gap-5 text-sm" aria-label="Main">
          {/* Supplements: anchor navigates to /products/ (works with JS off);
              adjacent chevron button toggles the categories dropdown */}
          <div class="relative flex items-center gap-0.5">
            <a
              href="/products/"
              class={`hover:text-saffron-deep ${Astro.url.pathname.startsWith('/products/') ? 'text-saffron-deep font-medium' : 'text-ink-soft'}`}
            >Supplements</a>
            <button
              type="button"
              id="supplements-toggle"
              class="p-1 -m-0.5 rounded text-ink-soft hover:text-saffron-deep focus:outline-none focus-visible:ring-2 focus-visible:ring-moss"
              aria-label="Browse supplement categories"
              aria-expanded="false"
              aria-controls="supplements-menu"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div
              id="supplements-menu"
              class="hidden absolute left-0 top-full mt-2 w-60 rounded-lg border border-mist bg-card shadow-dropdown py-2 z-30"
            >
              {CATEGORY_GROUPS.map((g) => (
                <a
                  href={`/products/#${g.id}`}
                  class="block px-4 py-2 text-sm text-ink-soft hover:text-saffron-deep hover:bg-paper-hover"
                >{g.label}</a>
              ))}
              <hr class="my-1.5 border-mist" />
              <a
                href="/products/"
                class="block px-4 py-2 text-sm font-medium text-moss-deep hover:text-saffron-deep hover:bg-paper-hover"
              >All supplements →</a>
            </div>
          </div>

          <a
            href="/blog/"
            class={`hover:text-saffron-deep ${Astro.url.pathname.startsWith('/blog/') ? 'text-saffron-deep font-medium' : 'text-ink-soft'}`}
          >Journal</a>
          <a
            href="/about/"
            class={`hover:text-saffron-deep ${Astro.url.pathname.startsWith('/about/') ? 'text-saffron-deep font-medium' : 'text-ink-soft'}`}
          >About</a>

          {/* Get help — kept in header for YMYL, visually secondary */}
          <a
            href="/get-help/"
            class={`text-xs pl-4 border-l border-mist hover:text-saffron-deep ${Astro.url.pathname.startsWith('/get-help/') ? 'text-saffron-deep font-medium' : 'text-ink-soft/80'}`}
          >Get help</a>
        </nav>

        {/* Search — desktop magnifier icon (mobile uses the drawer row) */}
        <a
          href="/search/"
          class={`hidden sm:inline-flex items-center justify-center w-8 h-8 rounded hover:text-saffron-deep focus:outline-none focus-visible:ring-2 focus-visible:ring-moss ${Astro.url.pathname.startsWith('/search') ? 'text-saffron-deep' : 'text-ink-soft'}`}
          aria-label="Search"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
            <path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </a>

        {/* Theme toggle — visible on desktop and the mobile header bar */}
        <ThemeToggle />

        {/* Mobile hamburger — visible only on small screens */}
        <button
          id="nav-toggle"
          class="sm:hidden flex flex-col justify-center gap-[5px] w-8 h-8 p-1 rounded focus:outline-none focus:ring-2 focus:ring-moss"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <span class="block h-0.5 w-full bg-moss-deep rounded transition-all" id="bar1"></span>
          <span class="block h-0.5 w-full bg-moss-deep rounded transition-all" id="bar2"></span>
          <span class="block h-0.5 w-full bg-moss-deep rounded transition-all" id="bar3"></span>
        </button>
        </div>
      </div>

      {/* Mobile nav drawer */}
      <nav
        id="mobile-nav"
        class="sm:hidden hidden flex-col border-t border-mist bg-paper/95"
        aria-label="Mobile navigation"
      >
        <a
          href="/search/"
          class={`px-5 py-3.5 text-sm border-b border-mist flex items-center gap-2 hover:text-saffron-deep hover:bg-paper-hover ${Astro.url.pathname.startsWith('/search') ? 'text-saffron-deep font-medium' : 'text-ink-soft'}`}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
            <path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Search
        </a>
        <a
          href="/products/"
          class={`px-5 py-3.5 text-sm border-b border-mist hover:text-saffron-deep hover:bg-paper-hover ${Astro.url.pathname.startsWith('/products/') ? 'text-saffron-deep font-medium' : 'text-ink-soft'}`}
        >Supplements</a>
        {CATEGORY_GROUPS.map((g) => (
          <a
            href={`/products/#${g.id}`}
            class="pl-9 pr-5 py-2.5 text-sm border-b border-mist text-ink-soft hover:text-saffron-deep hover:bg-paper-hover"
          >{g.label}</a>
        ))}
        <a
          href="/blog/"
          class={`px-5 py-3.5 text-sm border-b border-mist hover:text-saffron-deep hover:bg-paper-hover ${Astro.url.pathname.startsWith('/blog/') ? 'text-saffron-deep font-medium' : 'text-ink-soft'}`}
        >Journal</a>
        <a
          href="/about/"
          class={`px-5 py-3.5 text-sm border-b border-mist hover:text-saffron-deep hover:bg-paper-hover ${Astro.url.pathname.startsWith('/about/') ? 'text-saffron-deep font-medium' : 'text-ink-soft'}`}
        >About</a>
        <a
          href="/contact/"
          class={`px-5 py-3.5 text-sm border-b border-mist hover:text-saffron-deep hover:bg-paper-hover ${Astro.url.pathname.startsWith('/contact/') ? 'text-saffron-deep font-medium' : 'text-ink-soft'}`}
        >Contact</a>
        <a
          href="/get-help/"
          class={`px-5 py-3.5 text-sm border-b border-mist last:border-0 hover:text-saffron-deep hover:bg-paper-hover ${Astro.url.pathname.startsWith('/get-help/') ? 'text-saffron-deep font-medium' : 'text-ink-soft'}`}
        >Get help</a>
      </nav>
    </header>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const mobileNav = document.getElementById('mobile-nav');
      toggle?.addEventListener('click', () => {
        const isOpen = mobileNav?.classList.toggle('hidden') === false;
        mobileNav?.classList.toggle('flex', isOpen);
        toggle.setAttribute('aria-expanded', String(isOpen));
      });
    </script>

    <script>
      const supToggle = document.getElementById('supplements-toggle');
      const supMenu = document.getElementById('supplements-menu');

      function closeSupMenu() {
        supMenu?.classList.add('hidden');
        supToggle?.setAttribute('aria-expanded', 'false');
      }

      supToggle?.addEventListener('click', () => {
        const isOpen = supMenu?.classList.toggle('hidden') === false;
        supToggle.setAttribute('aria-expanded', String(isOpen));
      });

      // Escape closes and returns focus to the toggle button
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && supToggle?.getAttribute('aria-expanded') === 'true') {
          closeSupMenu();
          supToggle.focus();
        }
      });

      // Click outside closes
      document.addEventListener('click', (e) => {
        const target = e.target as Node | null;
        if (
          supToggle?.getAttribute('aria-expanded') === 'true' &&
          target &&
          !supMenu?.contains(target) &&
          !supToggle.contains(target)
        ) {
          closeSupMenu();
        }
      });

      // Selecting a category closes the menu (matters on /products/ hash links)
      supMenu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeSupMenu));
    </script>

    <script>
      declare global {
        interface Window { dataLayer: Record<string, unknown>[] }
      }
      window.dataLayer = window.dataLayer || [];
      document.addEventListener('click', (e) => {
        const el = (e.target as Element | null)?.closest?.('[data-affiliate]');
        if (!(el instanceof HTMLElement)) return;
        window.dataLayer.push({
          event: 'affiliate_click',
          product: el.dataset.product,
          placement: el.dataset.placement,
        });
      });
    </script>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="mt-16 border-t border-mist bg-moss-deep-surface text-paper-on-dark">
      <div class="mx-auto max-w-5xl px-5 py-10 grid gap-8 sm:grid-cols-3 text-sm">
        <div>
          <p class="font-display text-lg mb-2">{SITE.name}</p>
          <p class="opacity-80 leading-relaxed">{SITE.tagline}</p>
        </div>
        <div>
          <p class="eyebrow !text-mist-on-dark mb-2">Site</p>
          <ul class="space-y-1.5 opacity-90">
            <li><a href="/products/" class="hover:underline">All supplements</a></li>
            <li><a href="/blog/" class="hover:underline">Journal</a></li>
            <li><a href="/about/" class="hover:underline">About &amp; editorial standards</a></li>
            <li><a href="/contact/" class="hover:underline">Contact</a></li>
          </ul>
        </div>
        <div>
          <p class="eyebrow !text-mist-on-dark mb-2">Trust</p>
          <ul class="space-y-1.5 opacity-90">
            <li><a href="/disclosure/" class="hover:underline">Affiliate disclosure</a></li>
            <li><a href="/disclaimer/" class="hover:underline">Medical disclaimer</a></li>
            <li><a href="/get-help/" class="hover:underline">Crisis &amp; professional support</a></li>
          </ul>
        </div>
      </div>
      <div class="mx-auto max-w-5xl px-5 pb-8 text-xs leading-relaxed opacity-70 space-y-2">
        <p>
          MoodSupplement is reader-supported. When you buy through links on this site we may earn an
          affiliate commission, at no extra cost to you.
        </p>
        <p>
          Content on this site is for general information only and is not medical advice.
          Supplements are not a treatment for depression or any other medical condition. If you are
          struggling, please talk to a doctor or mental-health professional — and if you are in
          crisis, see our <a href="/get-help/" class="underline">Get help</a> page.
        </p>
        <p>© {year} {SITE.name}. These statements have not been evaluated by the FDA.</p>
      </div>
    </footer>
  </body>
</html>
